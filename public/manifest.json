{
  "manifest_version": 3,
  "name": "Lighter Alt+Click",
  "version": "0.1.0",
  "description": "Alt+Click price logger with per-ticker volume slots",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://app.lighter.xyz/*"],
  "action": {
    "default_title": "Lighter Alt+Click",
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://app.lighter.xyz/trade/*"],
      "js": ["assets/content.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/page-bridge.js"],
      "matches": ["https://app.lighter.xyz/*"]
    }
  ]
}
