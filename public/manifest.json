{
  "manifest_version": 3,
  "name": "One-Click Chart Scalper",
  "version": "0.1.0",
  "description": "Click-to-order scalping helper with configurable per-ticker volume slots",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "host_permissions": ["https://app.lighter.xyz/*", "https://lighter.exchange/*"],
  "action": {
    "default_title": "One-Click Chart Scalper",
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://app.lighter.xyz/trade/*", "https://lighter.exchange/trade/*"],
      "js": ["assets/content.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/page-bridge.js"],
      "matches": ["https://app.lighter.xyz/*", "https://lighter.exchange/*"]
    }
  ]
}
